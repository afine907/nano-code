# LLM 配置（三选一）

# 方式 1: OpenAI 兼容 API（如 LongCat、DeepSeek 等）
OPENAI_API_KEY=your-api-key
OPENAI_BASE_URL=https://api.longcat.chat/openai/v1
MODEL=LongCat-Flash-Chat

